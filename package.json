{
  "name": "syria-vpn-pro",
  "version": "1.0.0",
  "description": "Lightweight VPN app with premium US residential servers optimized for Syrian networks (Syriatel & MTN)",
  "main": "index.js",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild --clean",
    "build:android": "eas build --platform android --profile preview",
    "build:android:release": "eas build --platform android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~53.0.0",
    "expo-build-properties": "~0.13.1",
    "expo-constants": "~17.0.3",
    "expo-font": "~13.0.1",
    "expo-haptics": "~14.0.0",
    "expo-linear-gradient": "~14.0.1",
    "expo-splash-screen": "~0.29.13",
    "expo-status-bar": "~2.2.0",
    "expo-system-ui": "~4.0.4",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.21.2",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "15.0.1",
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
